generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Run {
  id            String   @id @default(cuid())
  providerType  String
  baseUrl       String
  modelClaim    String
  mode          String
  status        String
  riskLevel     String?
  finalScore    Float?
  confidence    Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  stageResults  StageResult[]
}

model StageResult {
  id        String   @id @default(cuid())
  runId     String
  stage     String
  score     Float
  flags     String
  evidence  String
  createdAt DateTime @default(now())
  run       Run      @relation(fields: [runId], references: [id], onDelete: Cascade)
}
